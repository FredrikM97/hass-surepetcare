{
  "name": "Python Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "GitHub.copilot"
      ]
    }
  },
  "containerEnv": {
    "UV_CACHE_DIR": "/home/vscode/.cache/uv",
    "UV_LINK_MODE": "copy"
  },
  "mounts": [
    "type=bind,source=${localEnv:HOME}/.ssh,target=/home/vscode/.ssh,readonly"
  ],
  "postCreateCommand": "pip install uv && uv sync --group dev && uv run pre-commit install",
  "postStartCommand": "git config --global --unset-all core.hooksPath || true"
}