{
  "name": "Python Dev Container",
  "image": "mcr.microsoft.com/devcontainers/python:3.13",
  "remoteUser": "vscode",
  "features": {},
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "charliermarsh.ruff",
        "GitHub.copilot"
      ]
    }
  },
  "mounts": [
    "type=bind,source=${localEnv:HOME}${localEnv:USERPROFILE}/.ssh,target=/home/vscode/.ssh,readonly"
  ],
  "containerEnv": {
    "UV_LINK_MODE": "copy",
    "UV_VENV_CLEAR": "1"
  },
  "postCreateCommand": "pip install --quiet uv && uv sync --group dev && uv run pre-commit install",
  "postStartCommand": "git config --global --unset-all core.hooksPath || true"
}